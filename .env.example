# MiniMax vision API key (used by the primary image/doc quote pipeline)
MINIMAX_API_KEY=replace_with_your_minimax_api_key

# Optional: override MiniMax text-chat endpoint/model for semantic supplement parsing.
# Defaults are suitable for the existing MiniMax API key.
MINIMAX_TEXT_URL=https://api.minimaxi.com/v1/chat/completions
MINIMAX_TEXT_MODEL=MiniMax-M2.7

# Legacy PaddleOCR layout parsing API config (optional fallback)
PADDLEOCR_BASE_URL=https://4au0y5nbbamev9w3.aistudio-app.com/layout-parsing
PADDLEOCR_API_KEY=replace_with_your_token
PADDLEOCR_AUTH_SCHEME=token
